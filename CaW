local function ToggleUI(minimize)
    local tInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    if minimize then
        TS:Create(Main, tInfo, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}):Play()
        task.wait(0.4)
        Main.Visible = false
        MinCircle.Visible = true
        MinCircle.Size = UDim2.new(0, 0, 0, 0)
        TS:Create(MinCircle, tInfo, {Size = UDim2.new(0, 50, 0, 50)}):Play()
    else
        TS:Create(MinCircle, tInfo, {Size = UDim2.new(0, 0, 0, 0)}):Play()
        task.wait(0.4)
        MinCircle.Visible = false
        Main.Visible = true
        TS:Create(Main, tInfo, {Size = UDim2.new(0, 500, 0, 320), BackgroundTransparency = 0.2}):Play()
    end
end

MinBtn.MouseButton1Click:Connect(function() ToggleUI(true) end)
MinCircle.MouseButton1Click:Connect(function() ToggleUI(false) end)

